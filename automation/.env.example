# ─── Google OAuth ────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console (OAuth 2.0 → Desktop app)
# Place it at: automation/credentials.json
# Then run: node src/auth.js   ← one-time browser login, creates token.json

# ─── Gmail (used by nodemailer) ───────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Company defaults ────────────────────────────────────────────────────────
COMPANY_NAME=YourCompany
HR_EMAIL=hr@yourcompany.com
IT_EMAIL=it@yourcompany.com

# ─── Single-employee quick-test (optional — ignored if employees.json exists) ─
EMPLOYEE_ID=EMP001
EMPLOYEE_NAME=Employee Full Name
EMPLOYEE_PERSONAL_EMAIL=employee@personal.com
EMPLOYEE_OFFICIAL_EMAIL=employee@company.com
EMPLOYEE_DOJ=2026-01-01
EMPLOYEE_DRIVE_FOLDER_ID=your-google-drive-folder-id

RECRUITER_EMAIL=recruiter@yourcompany.com
MANAGER_EMAIL=manager@yourcompany.com

# ─── Webhook server (Drive Push + Gmail Push) ────────────────────────────────
# For local dev: install ngrok, run `ngrok http 3000`, paste the https URL here.
# Leave as placeholder to fall back to Drive polling.
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app
WEBHOOK_PORT=3000

# ─── Gmail Pub/Sub (for reply parsing) ───────────────────────────────────────
# 1. Create a Pub/Sub topic in Google Cloud Console
# 2. Add gmail-api-push@system.gserviceaccount.com as Publisher on that topic
# 3. Add a Push subscription pointing to: WEBHOOK_BASE_URL/gmail-push
# 4. Paste the full topic name below:
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME

# ─── Pub/Sub subscription name (for /gmail-push origin verification) ─────────
# Paste the full subscription resource name, e.g.:
# projects/YOUR_PROJECT_ID/subscriptions/YOUR_SUBSCRIPTION_NAME
# If not set, subscription verification is skipped (less secure).
PUBSUB_SUBSCRIPTION_NAME=projects/YOUR_PROJECT_ID/subscriptions/YOUR_SUBSCRIPTION_NAME

# ─── Security: encryption + audit integrity ──────────────────────────────────
# AES-256-GCM key for encrypting state files at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, state files are stored as plain JSON.
MASTER_ENCRYPTION_KEY=

# HMAC-SHA256 key for tamper-evident audit log entries.
# Use any random string of at least 32 characters, e.g.: openssl rand -hex 32
# If not set, audit log entries are written without integrity signatures.
AUDIT_HMAC_KEY=

# ─── Data retention ──────────────────────────────────────────────────────────
# Number of days to keep activity and audit log files before auto-purge (default: 90)
LOG_RETENTION_DAYS=90

# ─── Optional ────────────────────────────────────────────────────────────────
ONBOARDING_SURVEY_LINK=https://forms.google.com/your-survey-link
# Pre-onboarding form link sent in the welcome email to new joiners
PREONBOARDING_FORM_LINK=https://forms.google.com/your-preonboarding-form
# Secret token for the POST /mark-task endpoint (recruiters use this to self-mark tasks)
# If not set, the endpoint is disabled. Use any random string, e.g. openssl rand -hex 16
MARK_TASK_SECRET=your-secret-token-here
